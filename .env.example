# ─── AI provider API keys ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Model selection (referenced by routing config via env keys) ────────────
OPENAI_DEFAULT_MODEL=
ANTHROPIC_DEFAULT_MODEL=
GROQ_DEFAULT_MODEL=
GEMINI_DEFAULT_MODEL=
MISTRAL_DEFAULT_MODEL=
OPENROUTER_DEFAULT_MODEL=

# ─── Per-stage model overrides (optional) ─────────────────────────────────────
INTENT_EXTRACTION_MODEL_OVERRIDE=
SCHEMA_GENERATION_MODEL_OVERRIDE=
APP_SPEC_GENERATION_MODEL_OVERRIDE=
REPAIR_MODEL_OVERRIDE=

# ─── Pipeline ───────────────────────────────────────────────────────────────
PIPELINE_MAX_RETRIES=3
PIPELINE_TIMEOUT_MS=120000
ENABLE_COST_TRACKING=true
LOG_LEVEL=info
